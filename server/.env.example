# Server
PORT=5000
NODE_ENV=development

# MongoDB
# Local: mongodb://localhost:27017
# Production: mongodb+srv://<user>:<pass>@cluster.mongodb.net/portfolio
MONGO_URI=mongodb://localhost:27017
DB_NAME=portfolio

# CORS (comma-separated, no trailing slash)
# Production: https://your-app.onrender.com
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# SMTP (Gmail — use App Password, NOT your real password)
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=shivanandgupta316@gmail.com
SMTP_PASS=your-app-password-here

# Where contact form emails are delivered
CONTACT_EMAIL=shivanandgupta316@gmail.com
